{
  "name": "@qahal/worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.toml",
    "deploy": "wrangler deploy --config wrangler.toml",
    "deploy:production": "wrangler deploy --env production --config wrangler.toml",
    "build": "wrangler deploy --dry-run --outdir build --config wrangler.toml",
    "typecheck": "tsc --noEmit",
    "cf:login": "wrangler login",
    "cf:whoami": "wrangler whoami",
    "cf:d1:create:test": "wrangler d1 create qahal-db-test",
    "cf:d1:create:prod": "wrangler d1 create qahal-db-prod",
    "cf:d1:migrate:test": "wrangler d1 migrations apply qahal-db-test --remote --config wrangler.toml",
    "cf:d1:migrate:prod": "wrangler d1 migrations apply qahal-db-prod --remote --config wrangler.toml",
    "cf:secret:bot:test": "wrangler secret put TELEGRAM_BOT_TOKEN --config wrangler.toml",
    "cf:secret:bot:prod": "wrangler secret put TELEGRAM_BOT_TOKEN --env production --config wrangler.toml",
    "cf:secret:initdata:test": "wrangler secret put INITDATA_MAX_AGE_SECONDS --config wrangler.toml",
    "cf:secret:initdata:prod": "wrangler secret put INITDATA_MAX_AGE_SECONDS --env production --config wrangler.toml",
    "cf:deploy:test": "wrangler deploy --config wrangler.toml",
    "cf:deploy:prod": "wrangler deploy --env production --config wrangler.toml",
    "cf:tail:test": "wrangler tail --config wrangler.toml",
    "cf:tail:prod": "wrangler tail --env production --config wrangler.toml"
  },
  "dependencies": {
    "@qahal/shared": "workspace:*",
    "hono": "^4.7.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.10.0"
  }
}
